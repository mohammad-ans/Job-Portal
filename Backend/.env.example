# ─────────────────────────────────────────────────────────────────────────────
# GradMatch AI — Backend environment variables
# Copy this file to .env and fill in real values before starting the server.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ─────────────────────────────────────────────────────────────────
# Full SQLAlchemy connection string.
# Dev (Docker Compose): postgresql+psycopg2://gradmatch:gradmatch@localhost:5432/gradmatch
# Production:           postgresql+psycopg2://USER:PASS@HOST:5432/DB_NAME
DATABASE_URL=postgresql+psycopg2://gradmatch:gradmatch@localhost:5432/gradmatch


# ── Authentication ────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret before deploying to production.
#   Linux/Mac: openssl rand -hex 32
#   Python:    python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-32-plus-character-random-string-before-production

# Token signing algorithm — do not change.
JWT_ALGORITHM=HS256

# How long access tokens remain valid (hours). Lower in production (e.g. 8).
JWT_EXPIRES_HOURS=24


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# Dev:         http://localhost:5173
# Production:  https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173


# ── File Uploads ──────────────────────────────────────────────────────────────
# Directories are relative to the Backend/ folder (created automatically).
# In production, consider moving to object storage (S3, R2, etc.).
RESUME_UPLOAD_DIR=./uploads/resumes
MAX_RESUME_MB=5


# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
# Dev: you can use the test key (re_...) — emails only go to your verified address.
# Production: verify your sending domain in the Resend dashboard first.
RESEND_API_KEY=re_your_api_key_here

# "From" address — must be on a domain you have verified in Resend.
# Format: Display Name <address@yourdomain.com>
RESEND_FROM=GradMatch AI <noreply@yourdomain.com>

# Public URL of your frontend — used to build the password-reset link in emails.
# Dev:        http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173


# ── Production checklist ──────────────────────────────────────────────────────
# 1. DATABASE_URL  →  point to a managed PostgreSQL instance (Neon, Supabase, RDS)
# 2. JWT_SECRET    →  cryptographically random, ≥ 32 chars, never reuse across envs
# 3. CORS_ORIGINS  →  your actual frontend domain(s) only, no trailing slash
# 4. HTTPS         →  run behind nginx / Caddy with TLS termination
# 5. Uploads       →  serve /uploads via nginx or a CDN, not FastAPI StaticFiles
# 6. RESEND_FROM   →  verify your domain in resend.com before going live
# 7. dev_seed.py   →  NEVER run in production
